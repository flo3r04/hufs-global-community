# Database connection string
# E.g. PostgreSQL URL: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://localhost:5432/hufs_db"

# JWT Secret for session minting (Any random strong string)
JWT_SECRET="your_jwt_secret_here"

# Kakao OAuth Client ID (REST API Key from Kakao Developers portal)
VITE_KAKAO_CLIENT_ID=""
